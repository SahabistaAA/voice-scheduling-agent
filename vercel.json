{
  "version": 2,
  "builds": [
    { "src": "source/main.py", "use": "@vercel/python" },
    { "src": "source/ui/package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" } }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/source/main" },
    { "source": "/assets/(.*)", "destination": "/source/ui/dist/assets/$1" },
    { "source": "/vite.svg", "destination": "/source/ui/dist/vite.svg" },
    { "source": "/(.*)", "destination": "/source/ui/dist/index.html" }
  ]
}