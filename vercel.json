{
  "version": 2,
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" },
    { "src": "source/ui/package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" } }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index" },
    { "src": "/(.*)", "dest": "/source/ui/dist/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/source/ui/dist/index.html" }
  ]
}